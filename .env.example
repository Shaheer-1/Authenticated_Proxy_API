# Database connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/auth_server_db"

# JWT secret — use a long, random string in production
JWT_SECRET="change-me-to-a-random-secret"

# OpenWeatherMap API key — server-side only (https://openweathermap.org/api)
OPENWEATHER_API_KEY=""

# CORS allowed origins (comma-separated). Unset = allow all (dev only).
# Example: CORS_ORIGIN="http://localhost:5173,https://app.example.com"
CORS_ORIGIN=""
